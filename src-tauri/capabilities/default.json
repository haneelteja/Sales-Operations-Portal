{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimum required permissions for the Aamodha Operations Portal desktop app. Follow least-privilege: add permissions only as features require them.",
  "windows": ["main"],
  "permissions": [
    "core:default",

    "shell:allow-open",

    "fs:read-files",
    "fs:write-files",
    "fs:read-dirs",
    "fs:scope-download",

    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-ask",
    "dialog:allow-message",

    "notification:default",

    "updater:default",

    "process:allow-exit",

    "os:allow-platform",
    "os:allow-version",

    "store:allow-load",
    "store:allow-set",
    "store:allow-get",
    "store:allow-delete",
    "store:allow-save"
  ]
}
